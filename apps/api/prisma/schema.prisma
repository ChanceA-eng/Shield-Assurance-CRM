datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id          String    @id @default(uuid())
  name        String
  isCorporate Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contacts    Contact[]
  deals       Deal[]
}

model Contact {
  id         String     @id @default(uuid())
  accountId  String
  account    Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  email      String     @unique
  phone      String?
  createdAt  DateTime   @default(now())
  activities Activity[]
}

model Deal {
  id           String    @id @default(uuid())
  accountId    String
  account      Account   @relation(fields: [accountId], references: [id])
  title        String
  stage        DealStage @default(LEAD)
  amount       Float?
  lineType     LineType
  customFields Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Activity {
  id         String       @id @default(uuid())
  contactId  String
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type       ActivityType
  direction  Direction    @default(INBOUND)
  subject    String
  body       String
  externalId String?
  createdAt  DateTime     @default(now())
}

model KnowledgeDocument {
  id           String                  @id @default(uuid())
  title        String
  sourceType   SourceType
  sourceUrl    String?
  carrierName  String?
  stateContext String?
  policyType   String?
  topic        String?
  topicTags    String[]                @default([])
  summary      String?
  rawText      String?
  status       DocumentStatus          @default(PENDING)
  errorMessage String?
  insights     DocumentInsight[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([carrierName])
  @@index([stateContext])
  @@index([policyType])
  @@index([topic])
  @@index([status])
}

model DocumentInsight {
  id              String            @id @default(uuid())
  documentId      String
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  insightIndex    Int
  content         String
  embedding       Unsupported("vector")?
  embeddingValues Float[]           @default([])
  createdAt       DateTime          @default(now())

  @@unique([documentId, insightIndex])
  @@index([documentId])
}

enum DealStage {
  LEAD
  QUOTING
  PRESENTED
  BOUND
  LOST
}

enum LineType {
  P_C
  LIFE_HEALTH
}

enum ActivityType {
  EMAIL
  SMS
  CALL
  SYSTEM_NOTE
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum SourceType {
  PDF
  ARTICLE
  LINK
  VIDEO_TRANSCRIPT
  NOTE
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model ChatSession {
  id        String        @id @default(uuid())
  scope     Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime    @default(now())

  @@index([sessionId])
}
