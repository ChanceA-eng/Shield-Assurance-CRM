datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id          String    @id @default(uuid())
  name        String
  isCorporate Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contacts    Contact[]
  deals       Deal[]
}

model Contact {
  id         String     @id @default(uuid())
  accountId  String
  account    Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  email      String     @unique
  phone      String?
  createdAt  DateTime   @default(now())
  activities Activity[]
}

model Deal {
  id           String    @id @default(uuid())
  accountId    String
  account      Account   @relation(fields: [accountId], references: [id])
  title        String
  stage        DealStage @default(LEAD)
  amount       Float?
  lineType     LineType
  customFields Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Activity {
  id         String       @id @default(uuid())
  contactId  String
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type       ActivityType
  direction  Direction    @default(INBOUND)
  subject    String
  body       String
  externalId String?
  createdAt  DateTime     @default(now())
}

model KnowledgeDocument {
  id           String                  @id @default(uuid())
  title        String
  sourceType   SourceType
  sourceUrl    String?
  carrierName  String?
  stateContext String?
  policyType   String?
  topic        String?
  topicTags    String[]                @default([])
  summary      String?
  rawText      String?
  status       DocumentStatus          @default(PENDING)
  errorMessage String?
  insights     DocumentInsight[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([carrierName])
  @@index([stateContext])
  @@index([policyType])
  @@index([topic])
  @@index([status])
}

model DocumentInsight {
  id              String            @id @default(uuid())
  documentId      String
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  insightIndex    Int
  content         String
  embedding       Unsupported("vector")?
  embeddingValues Float[]           @default([])
  createdAt       DateTime          @default(now())

  @@unique([documentId, insightIndex])
  @@index([documentId])
}

enum DealStage {
  LEAD
  QUOTING
  PRESENTED
  BOUND
  LOST
}

enum LineType {
  P_C
  LIFE_HEALTH
}

enum ActivityType {
  EMAIL
  SMS
  CALL
  SYSTEM_NOTE
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum SourceType {
  PDF
  ARTICLE
  LINK
  VIDEO_TRANSCRIPT
  NOTE
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model ChatSession {
  id        String        @id @default(uuid())
  scope     Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model Client {
  id               String            @id @default(uuid())
  fullName         String            @map("full_name")
  phone            String?
  email            String?
  address          String?
  source           String?
  emailConsent     Boolean?          @map("email_consent")
  smsConsent       Boolean?          @map("sms_consent")
  preferredChannel String?           @map("preferred_channel")
  createdAt        DateTime?         @default(now()) @map("created_at")
  policies         Policy[]
  communications   CommunicationLog[]
  assets           ClientAsset[]
  clientTasks      ClientTask[]
  files            ClientFile[]
  tags             ClientTag[]
  activities       ClientActivity[]

  @@map("clients")
}

model Policy {
  id             String   @id @default(uuid())
  clientId       String?  @map("client_id")
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  insuredName    String   @map("insured_name")
  phone          String?
  email          String?
  address        String?
  carrier        String
  lineOfBusiness String   @map("line_of_business")
  premium        Float?
  policyNumber   String?  @map("policy_number")
  effectiveDate  DateTime @map("effective_date")
  renewalDate    DateTime @map("renewal_date")
  status         String
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@map("policies")
}

model CommunicationLog {
  id             String   @id @default(uuid())
  clientId       String?  @map("client_id")
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel        String?
  direction      String?
  subject        String?
  body           String?
  sentAt         DateTime? @default(now()) @map("sent_at")
  automationType String?  @map("automation_type")
  metadata       Json?

  @@index([clientId, sentAt])
  @@map("communication_log")
}

model ClientAsset {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  assetType String   @default("general") @map("asset_type")
  value     String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([clientId])
  @@map("client_assets")
}

model ClientTask {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject     String
  description String?
  dueDate     DateTime? @map("due_date")
  status      String   @default("open")
  priority    String   @default("medium")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@index([clientId])
  @@map("client_tasks")
}

model ClientFile {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileName   String   @map("file_name")
  fileUrl    String?  @map("file_url")
  fileType   String?  @map("file_type")
  fileSize   BigInt?  @map("file_size")
  status     String   @default("uploaded")
  metadata   Json?
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@map("client_files")
}

model ClientTag {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag       String
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([clientId, tag])
  @@index([clientId])
  @@map("client_tags")
}

model ClientActivity {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  activityType String   @map("activity_type")
  title        String
  body         String?
  metadata     Json?
  occurredAt   DateTime @default(now()) @map("occurred_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@map("client_activities")
}
